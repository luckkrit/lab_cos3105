{
  "name": "OS Development Workspace",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  
  // สั่งให้รันคำสั่งติดตั้ง NASM, QEMU และ GCC ทันทีหลังจากสร้าง Container เสร็จ
  "postCreateCommand": "sudo apt-get update && sudo apt-get install -y nasm qemu-system-x86 qemu-utils build-essential",

  // ติดตั้ง Extensions ที่จำเป็นให้พร้อมใช้งานบนเบราว์เซอร์อัตโนมัติ
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools",       // สำหรับ ไฮไลต์สีโค้ดภาษา C/C++
        "mcu-debug.rtos-views",     // เผื่อใช้ดูสถานะหน่วยความจำ
        "13xforever.language-x86-64-assembly" // สำหรับไฮไลต์สีโค้ด Assembly (NASM)
      ]
    }
  }
}