{
  "name": "OS Development Workspace",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  
  // เพิ่ม git-lfs และ git lfs install ต่อท้ายเข้าไปในคำสั่งเดิม
  "postCreateCommand": "sudo apt-get update && sudo apt-get install -y nasm qemu-system-x86 qemu-utils build-essential git-lfs libnewt-dev whiptail gdb && git lfs install",

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools",
        "mcu-debug.rtos-views",
        "13xforever.language-x86-64-assembly",
        "ms-vscode.cpp-devtools",
        "ms-vscode.cpptools-extension-pack",
        "ms-vscode.cpptools-themes",
        "ms-vscode.cmake-tools",
        "mcu-debug.debug-tracker-vscode"
      ]
    }
  }
}
